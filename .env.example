# ============================================================
# DemoForge — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Supabase (required) ---
# Found in your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Database (required) ---
# Supabase: Settings > Database > Connection string
# Use the "Transaction" pooler URL for DATABASE_URL (port 6543)
# Use the "Session" or direct URL for DIRECT_URL (port 5432)
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.your-project-ref:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# --- Anthropic Claude API (required) ---
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- GitHub OAuth App (required for repo analysis) ---
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/auth/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# --- App URL (required for OAuth redirects) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
